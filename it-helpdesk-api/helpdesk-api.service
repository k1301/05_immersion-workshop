[Unit]
Description=IT Helpdesk API Service
After=network.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/home/ec2-user/it-helpdesk-api
Environment="PATH=/home/ec2-user/it-helpdesk-api/venv/bin"
ExecStart=/home/ec2-user/it-helpdesk-api/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
