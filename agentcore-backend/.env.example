# AWS 설정
AWS_REGION=us-east-1
AWS_PROFILE=default

# Bedrock 모델 (기본값 - US Inference Profile)
# 사용 가능한 모델: sonnet-4.6, sonnet-4.5, sonnet-3.7, opus-4.6, opus-4.1, haiku-4.5, haiku-3.5, haiku-3
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# 비교할 모델들 (쉼표로 구분, 선택사항)
# 예: COMPARE_MODELS=sonnet-4.6,opus-4.6,haiku-3.5
COMPARE_MODELS=

# API 설정 (나중에 사용)
API_PORT=8001
API_HOST=0.0.0.0

# 로그 레벨
LOG_LEVEL=INFO
